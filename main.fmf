discover:
  how: shell
  tests:
    - name: /tree-dev
      test: tree /dev
    - name: /rocminfo
      test: rocminfo
    - name: /rocm-clinfo
      test: rocm-clinfo
provision:
  how: container
  expose-device:
    # - /dev/dri/card0
    # - /dev/dri/card1
    # - /dev/dri/card2
    - /dev/dri
    - /dev/kfd
prepare:
  how: install
  package:
    - tree
    - rocm
execute:
  how: tmt
